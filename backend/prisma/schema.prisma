generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workflow {
  id           Int      @id @default(autoincrement())
  name         String
  objective    String
  instructions String
  createdAt    DateTime @default(now())

  cases        Case[]
}

model Case {
  id           Int      @id @default(autoincrement())
  customerName String
  email        String?
  amountDue    Float
  status       String   @default("NEW")

  workflowId   Int
  workflow     Workflow @relation(fields: [workflowId], references: [id])

  sessionToken String   @unique

  messages     Message[]
  actionLogs   ActionLog[]
  escalation   Escalation?

  createdAt    DateTime @default(now())
}

model Message {
  id        Int      @id @default(autoincrement())
  role      String
  content   String

  caseId    Int
  case      Case     @relation(fields: [caseId], references: [id])

  createdAt DateTime @default(now())
}

model ActionLog{
  id        Int      @id @default(autoincrement())
  action    String
  reason    String?
  createdAt DateTime @default(now())

  caseId    Int
  case      Case     @relation(fields: [caseId], references: [id])
}

model Escalation {
  id         Int      @id @default(autoincrement())
  reason     String
  createdAt  DateTime @default(now())

  caseId     Int      @unique
  case       Case     @relation(fields: [caseId], references: [id])
}
